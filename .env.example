# ── Database ──
# Development (local):
DATABASE_URL="postgresql://localhost:5432/higsi_v2?schema=public"
#
# Production (direct with pooling):
# DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public&connection_limit=10"
#
# Production (PgBouncer transaction mode):
# DATABASE_URL="postgresql://user:pass@host:6543/db?schema=public&pgbouncer=true&connection_limit=5"
#
# Production (Prisma Accelerate):
# DATABASE_URL="prisma+accelerate://accelerate://your-api-key"

# ── NextAuth ──
# Generate a fresh secret: openssl rand -hex 32
AUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars"
AUTH_URL="http://localhost:3000"
# Production AUTH_URL:
# AUTH_URL="https://your-domain.com"

# ── File access link signing ──
# Generate: openssl rand -hex 32
FILE_SIGNING_KEY="change-me-to-a-random-key-at-least-32-chars"

# ── Object Storage ──
# Development keeps the compatibility filesystem adapter until PR-5B/PR-5C.
STORAGE_PROVIDER="local"
STORAGE_LOCAL_ROOT="./private/data"
# Production must use s3, separate environment-specific buckets, SSE-KMS,
# and workload identity/IAM roles. Do not add static AWS credentials here.
# STORAGE_PROVIDER="s3"
# AWS_REGION="us-east-2"
# S3_DURABLE_BUCKET="change-me-production-durable"
# S3_QUARANTINE_BUCKET="change-me-production-quarantine"
# S3_KMS_KEY_ARN="arn:aws:kms:us-east-2:000000000000:key/change-me"
# S3_SIGNED_URL_TTL_SECONDS="60"
# S3_ENDPOINT is non-production-only and is not required for local development.

# ── Error Tracking (Sentry) ──
# Optional — skip if not using Sentry
# NEXT_PUBLIC_SENTRY_DSN="https://key@oXXX.ingest.sentry.io/project"
# SENTRY_DSN="${NEXT_PUBLIC_SENTRY_DSN}"
