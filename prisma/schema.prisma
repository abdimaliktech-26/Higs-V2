generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  SUPER_ADMIN
  ORG_ADMIN
  COMPLIANCE_DIRECTOR
  CASE_MANAGER
  DSP
  NURSE
  BILLING_ADMIN
  GUARDIAN
  EXTERNAL_CASE_MANAGER
}

enum OrganizationStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  CANCELLED
}

enum MemberStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum AuditAction {
  LOGIN
  LOGOUT
  ORGANIZATION_SWITCH
  USER_CREATED
  USER_UPDATED
  ROLE_CHANGED
  CLIENT_VIEWED
  CLIENT_CREATED
  CLIENT_UPDATED
  CLIENT_ARCHIVED
  STAFF_ASSIGNED
  STAFF_UNASSIGNED
  CONTACT_ADDED
  CONTACT_UPDATED
  CONTACT_REMOVED
  MEMBER_CREATED
  MEMBER_UPDATED
  PACKET_VIEWED
  PACKET_CREATED
  PACKET_STATUS_CHANGED
  PACKET_DOCUMENT_STATUS_CHANGED
  DOCUMENT_VIEWED
  DOCUMENT_EDITED
  DOCUMENT_SAVED
  DOCUMENT_FIELD_ADDED
  DOCUMENT_FIELD_UPDATED
  PDF_VERSION_CREATED
  DOCUMENT_COMMENT_ADDED
  SETTINGS_UPDATED
  EXPORT_PERFORMED
  TEMPLATE_UPLOADED
  TEMPLATE_ACTIVATED
  TEMPLATE_RETIRED
  PACKET_TEMPLATE_CREATED
  PACKET_TEMPLATE_DOCUMENT_UPDATED
  DOCUMENT_TEMPLATE_VERSION_CREATED
  TEMPLATE_FIELD_CREATED
  TEMPLATE_FIELD_UPDATED
  TEMPLATE_FIELD_DELETED
  VALIDATION_RULE_STATUS_CHANGED
  TEMPLATE_CONDITION_CREATED
  TEMPLATE_CONDITION_UPDATED
  TEMPLATE_CONDITION_DELETED
  VALIDATION_RUN
  VALIDATION_ISSUE_CREATED
  VALIDATION_ISSUE_RESOLVED
  COMPLIANCE_SCORE_UPDATED
  SIGNATURE_REQUESTED
  SIGNATURE_SENT
