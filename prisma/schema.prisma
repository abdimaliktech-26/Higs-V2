model PortalClientAccess {
  id                      String             @id @default(cuid())
  portalUserId            String             @map("portal_user_id")
  clientId                String             @map("client_id")
  organizationId          String             @map("organization_id")
  clientContactId         String?            @map("client_contact_id")
  relationship            String
  accessRole              PortalAccessRole   @map("access_role")
  status                  PortalAccessStatus @default(ACTIVE)
  grantedByUserId         String             @map("granted_by_user_id")
  grantedAt               DateTime           @default(now()) @map("granted_at")
  expiresAt               DateTime?          @map("expires_at")
  revokedAt               DateTime?          @map("revoked_at")
  revokedByUserId         String?            @map("revoked_by_user_id")
  revocationReason        String?            @map("revocation_reason")
  canViewDocuments        Boolean            @default(false) @map("can_view_documents")
  canUploadDocuments      Boolean            @default(false) @map("can_upload_documents")
  canSignDocuments        Boolean            @default(false) @map("can_sign_documents")
  canViewAppointments     Boolean            @default(false) @map("can_view_appointments")
  canMessageCareTeam      Boolean            @default(false) @map("can_message_care_team")
  canManageOtherGuardians Boolean            @default(false) @map("can_manage_other_guardians")
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt

  portalUser        PortalUser                  @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  client            Client                      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  organization      Organization                @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  clientContact     ClientContact?              @relation(fields: [clientContactId], references: [id], onDelete: SetNull)
  grantedBy         User                        @relation("PortalAccessGrantedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedBy         User?                       @relation("PortalAccessRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  authorizations    PortalAccessAuthorization[]
  signatureRequests SignatureRequest[]          @relation("PortalSignerAccessGrant")

  // Prisma has no partial/filtered unique index support, so "one active grant
  // per portal user/client" cannot be expressed here. Enforced via a raw
  // partial unique index added directly to the generated migration SQL
  // (portal_client_access_one_active) plus an application-layer check before insert.
  @@index([portalUserId, clientId, status])
  @@index([clientId, status])
  @@index([organizationId, status])
  @@map("portal_client_access")
}

