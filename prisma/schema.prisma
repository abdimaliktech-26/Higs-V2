model SupportingDocument {
  id                     String                             @id @default(cuid())
  organizationId         String                             @map("organization_id")
  clientId               String?                            @map("client_id")
  packetId               String?                            @map("packet_id")
  title                  String
  category               String                             @default("supporting")
  fileUrl                String                             @map("file_url")
  fileKey                String                             @map("file_key")
  fileSize               Int?                               @map("file_size")
  mimeType               String                             @default("application/pdf") @map("mime_type")
  status                 String                             @default("active")
  description            String?
  portalVisible          Boolean                            @default(false) @map("portal_visible")
  portalVisibleAt        DateTime?                          @map("portal_visible_at")
  sharedByUserId         String?                            @map("shared_by_user_id")
  portalAccessLevel      PortalDocumentAccessLevel?         @map("portal_access_level")
  uploadedById           String?                            @map("uploaded_by_id")
  uploadedByPortalUserId String?                            @map("uploaded_by_portal_user_id")
  portalRequestId        String?                            @map("portal_request_id")
  originalFileName       String?                            @map("original_file_name")
  // Nullable, no schema-level default — only ever set by the portal upload
  // route for request-fulfillment uploads. Staff-uploaded SupportingDocument
  // rows (library.ts, templates.ts) never touch this field and stay null,
  // so existing staff behavior around the generic `status` field above is
  // completely unaffected.
  reviewStatus           PortalDocumentReviewOutcomeStatus? @map("review_status")
  createdAt              DateTime                           @default(now())
  updatedAt              DateTime                           @updatedAt

  organization         Organization                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client               Client?                        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  packet               Packet?                        @relation(fields: [packetId], references: [id], onDelete: SetNull)
  uploadedBy           User?                          @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  uploadedByPortalUser PortalUser?                    @relation(fields: [uploadedByPortalUserId], references: [id], onDelete: SetNull)
  portalRequest        PortalDocumentRequest?         @relation(fields: [portalRequestId], references: [id], onDelete: SetNull)
  sharedBy             User?                          @relation("PortalDocumentSharedBy", fields: [sharedByUserId], references: [id], onDelete: SetNull)
  portalAuthorizations PortalAccessAuthorization[]
  timelineEvents       PortalDocumentTimelineEvent[]
  reviewFeedback       PortalDocumentReviewFeedback[]

  @@index([portalRequestId])
  @@map("supporting_documents")
}

