  clientId             String              @map("client_id")
  portalUserId         String              @map("portal_user_id")
  accessGrantId        String              @map("access_grant_id")
  grantedByUserId      String              @map("granted_by_user_id")
  authorityType        PortalAuthorityType @map("authority_type")
  scope                Json                @default("{}")
  effectiveDate        DateTime            @map("effective_date")
  expirationDate       DateTime?           @map("expiration_date")
  supportingDocumentId String?             @map("supporting_document_id")
  consentText          String              @map("consent_text")
  consentVersion       String              @map("consent_version")
  acceptedAt           DateTime?           @map("accepted_at")
  acceptedIp           String?             @map("accepted_ip")
  acceptedUserAgent    String?             @map("accepted_user_agent")
  revokedAt            DateTime?           @map("revoked_at")
  revokedByUserId      String?             @map("revoked_by_user_id")
  createdAt            DateTime            @default(now())

  client             Client              @relation(fields: [clientId], references: [id], onDelete: Restrict)
  portalUser         PortalUser          @relation(fields: [portalUserId], references: [id], onDelete: Restrict)
  accessGrant        PortalClientAccess  @relation(fields: [accessGrantId], references: [id], onDelete: Restrict)
  grantedBy          User                @relation("PortalAuthorizationVerifiedBy", fields: [grantedByUserId], references: [id], onDelete: Restrict)
  revokedBy          User?               @relation("PortalAuthorizationRevokedBy", fields: [revokedByUserId], references: [id], onDelete: SetNull)
  supportingDocument SupportingDocument? @relation(fields: [supportingDocumentId], references: [id], onDelete: SetNull)

  // One PortalClientAccess grant may accumulate several authorization records
  // over time (renewed guardianship order, amended scope) — intentionally
  // not unique on accessGrantId. Exactly one "current" row is an
  // application-layer invariant, not a DB constraint.
  @@index([clientId, portalUserId])
  @@index([accessGrantId])
  @@map("portal_access_authorizations")
}

model PortalNotification {
  id             String    @id @default(cuid())
  organizationId String    @map("organization_id")
  portalUserId   String    @map("portal_user_id")
  clientId       String    @map("client_id")
  type           String    @default("info")
  title          String
  message        String
  link           String?
  metadata       Json      @default("{}")
  readAt         DateTime? @map("read_at")
  dismissedAt    DateTime? @map("dismissed_at")
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  portalUser   PortalUser   @relation(fields: [portalUserId], references: [id], onDelete: Cascade)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([portalUserId, readAt])
  @@index([clientId])
  @@map("portal_notifications")
}

model PortalAuditEvent {
  id             String            @id @default(cuid())
  organizationId String?           @map("organization_id")
  portalUserId   String?           @map("portal_user_id")
  clientId       String?           @map("client_id")
  action         PortalAuditAction
  targetType     String?           @map("target_type")
  targetId       String?           @map("target_id")
  metadata       Json              @default("{}")
  ipAddress      String?           @map("ip_address")
  userAgent      String?           @map("user_agent")
  createdAt      DateTime          @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  portalUser   PortalUser?   @relation("PortalAuditActor", fields: [portalUserId], references: [id], onDelete: SetNull)
  client       Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([portalUserId])
  @@index([clientId, createdAt])
  @@index([action])
  @@map("portal_audit_events")
}

enum PortalDocumentRequestStatus {
  PENDING
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  NEEDS_REPLACEMENT
  CANCELLED
}

enum PortalDocumentRequestPriority {
  LOW
  NORMAL
  HIGH
}

enum PortalDocumentCategory {
  INSURANCE
  IDENTIFICATION
  MEDICATION
  CARE_PLAN
  LEGAL
  CONSENT
  PHOTO
  OTHER
}

/**
 * Stage 4 Step 1 (Document Request Engine): the "ask" — staff requesting a
 * specific document from a client/guardian through the portal. Upload
 * fulfillment (Step 2), review workflow (Step 3), full timeline event log
 * (Step 4), and notifications (Step 5) are intentionally not modeled yet —
 * this only covers request creation and its own PENDING/CANCELLED lifecycle.
 * SUBMITTED/UNDER_REVIEW/APPROVED/NEEDS_REPLACEMENT are defined now (full
 * blueprint) but unreachable until later steps add the code that sets them.
 */
model PortalDocumentRequest {
  id                 String                        @id @default(cuid())
  organizationId     String                        @map("organization_id")
  clientId           String                        @map("client_id")
  packetId           String?                       @map("packet_id")
  packetDocumentId   String?                       @map("packet_document_id")
  title              String
  description        String?
  category           PortalDocumentCategory
  priority           PortalDocumentRequestPriority @default(NORMAL)
  isRequired         Boolean                       @default(true) @map("is_required")
  dueDate            DateTime?                     @map("due_date")
  status             PortalDocumentRequestStatus   @default(PENDING)
  requestedByUserId  String                        @map("requested_by_user_id")
  cancelledAt        DateTime?                     @map("cancelled_at")
  cancelledByUserId  String?                       @map("cancelled_by_user_id")
  cancellationReason String?                       @map("cancellation_reason")
  createdAt          DateTime                      @default(now())
  updatedAt          DateTime                      @updatedAt

  organization        Organization                   @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  client              Client                         @relation(fields: [clientId], references: [id], onDelete: Restrict)
  packet              Packet?                        @relation(fields: [packetId], references: [id], onDelete: SetNull)
  packetDocument      PacketDocument?                @relation(fields: [packetDocumentId], references: [id], onDelete: SetNull)
  requestedBy         User                           @relation("PortalDocumentRequestCreatedBy", fields: [requestedByUserId], references: [id], onDelete: Restrict)
  cancelledBy         User?                          @relation("PortalDocumentRequestCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  supportingDocuments SupportingDocument[]
  timelineEvents      PortalDocumentTimelineEvent[]
  reviewFeedback      PortalDocumentReviewFeedback[]

  @@index([organizationId, clientId, status])
  @@index([clientId, status])
  @@index([dueDate])
  @@map("portal_document_requests")
}

enum PortalDocumentTimelineEventType {
  REQUESTED
  UPLOADED
  RESUBMITTED
  CANCELLED
  UNDER_REVIEW
  APPROVED
  NEEDS_REPLACEMENT
  FEEDBACK_ADDED
}

enum PortalDocumentReviewOutcomeStatus {
  PENDING_REVIEW
  UNDER_REVIEW
  APPROVED
  NEEDS_REPLACEMENT
  SUPERSEDED
}

enum PortalDocumentReviewCategory {
  PHOTO_QUALITY
  UNREADABLE
  MISSING_PAGES
  WRONG_DOCUMENT
  INCOMPLETE
  EXPIRED
  MISMATCHED_INFO
  OTHER
}

enum PortalDocumentReviewSeverity {
  REQUIRED
  SUGGESTED
}

/**
 * Stage 4 Step 2 foundation: append-only event log for a document request,
 * named generically (not "RequestEvent") so it can absorb future event
 * types (review decisions, downloads, views) without a model rename —
 * mirrors the SignatureEvent/ApprovalEvent pattern already used elsewhere.
 * Only REQUESTED/UPLOADED/RESUBMITTED/CANCELLED are ever written as of
 * Step 2; review-related event types are deferred to a later step.
 */
model PortalDocumentTimelineEvent {
  id                    String                          @id @default(cuid())
  requestId             String                          @map("request_id")
  eventType             PortalDocumentTimelineEventType
  supportingDocumentId  String?                         @map("supporting_document_id")
  createdByPortalUserId String?                         @map("created_by_portal_user_id")
  createdByUserId       String?                         @map("created_by_user_id")
  note                  String?
  createdAt             DateTime                        @default(now())

  request             PortalDocumentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supportingDocument  SupportingDocument?   @relation(fields: [supportingDocumentId], references: [id], onDelete: SetNull)
  createdByPortalUser PortalUser?           @relation(fields: [createdByPortalUserId], references: [id], onDelete: SetNull)
  createdByUser       User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([requestId, createdAt])
  @@map("portal_document_timeline_events")
}

/**
 * Client-visible reviewer feedback — deliberately a separate model from the
 * internal, staff-only DocumentComment, never the other. Every row here is
 * shown to the portal user by design; there is no "internal-only" mode.
 */
model PortalDocumentReviewFeedback {
  id                   String                       @id @default(cuid())
  requestId            String                       @map("request_id")
  supportingDocumentId String?                      @map("supporting_document_id")
  reviewerUserId       String                       @map("reviewer_user_id")
  note                 String
  category             PortalDocumentReviewCategory
  severity             PortalDocumentReviewSeverity
  createdAt            DateTime                     @default(now())

  request            PortalDocumentRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  supportingDocument SupportingDocument?   @relation(fields: [supportingDocumentId], references: [id], onDelete: SetNull)
  reviewer           User                  @relation(fields: [reviewerUserId], references: [id], onDelete: Restrict)

  @@index([requestId, createdAt])
  @@map("portal_document_review_feedback")
}
