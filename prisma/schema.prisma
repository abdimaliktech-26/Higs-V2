  SUSPENDED
  LOCKED
  DEACTIVATED
}

enum PortalAccessRole {
  CLIENT_SELF
  GUARDIAN
  PARENT
  RESPONSIBLE_PARTY
  AUTHORIZED_REPRESENTATIVE
}

enum PortalAccessStatus {
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

