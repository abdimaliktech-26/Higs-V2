model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  status    OrganizationStatus @default(ACTIVE)
  plan      String             @default("starter")
  settings  Json               @default("{}")
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  members                  OrganizationMember[]
  clients                  Client[]
  packets                  Packet[]
  programs                 Program[]
  packetTemplates          PacketTemplate[]
  documentTemplates        DocumentTemplate[]
  documentTemplateFields   DocumentTemplateField[]
  templateConditionGroups  TemplateConditionGroup[]
  validationRules          ValidationRule[]
  validationResults        ValidationResult[]
  signatureRequests        SignatureRequest[]
  approvalRequests         ApprovalRequest[]
  supportingDocuments      SupportingDocument[]
  aiExtractions            AiExtraction[]
  aiRecommendations        AiRecommendation[]
  notifications            Notification[]
  auditEvents              AuditEvent[]
  portalClientAccess       PortalClientAccess[]
  portalInvitations        PortalInvitation[]
  portalNotifications      PortalNotification[]
  portalAuditEvents        PortalAuditEvent[]
  portalDocumentRequests   PortalDocumentRequest[]
  packetConditionSnapshots PacketConditionSnapshot[]

  @@map("organizations")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  passwordHash  String?
  emailVerified DateTime?
  isSuperAdmin  Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts                        Account[]
  sessions                        Session[]
  memberships                     OrganizationMember[]
  staffAssignments                StaffAssignment[]
  uploadedTemplates               DocumentTemplate[]             @relation("TemplateUploads")
  assignedPackets                 Packet[]                       @relation("AssignedPackets")
  pdfVersionsCreated              PdfVersion[]
  documentCommentsCreated         DocumentComment[]
  validationRuns                  ValidationResult[]             @relation("ValidationRuns")
  resolvedValidationIssues        ValidationIssue[]              @relation("IssueResolver")
  requestedSignatures             SignatureRequest[]             @relation("SignatureRequestor")
  signatureEventsCreated          SignatureEvent[]
  submittedApprovals              ApprovalRequest[]              @relation("ApprovalSubmitter")
  approvalsDecided                ApprovalRequest[]              @relation("Approver")
  approvalEventsCreated           ApprovalEvent[]
  uploadedSupportingDocuments     SupportingDocument[]
  aiExtractionRuns                AiExtraction[]                 @relation("AiExtractionRuns")
  appliedAiRecommendations        AiRecommendation[]             @relation("AppliedAiRecommendations")
  notifications                   Notification[]
  createdAuditEvents              AuditEvent[]                   @relation("AuditEventActor")
  portalAccessGranted             PortalClientAccess[]           @relation("PortalAccessGrantedBy")
  portalAccessRevoked             PortalClientAccess[]           @relation("PortalAccessRevokedBy")
  portalInvitationsSent           PortalInvitation[]             @relation("PortalInvitationSentBy")
  portalInvitationsRevoked        PortalInvitation[]             @relation("PortalInvitationRevokedBy")
  portalAuthorizationsVerified    PortalAccessAuthorization[]    @relation("PortalAuthorizationVerifiedBy")
  portalAuthorizationsRevoked     PortalAccessAuthorization[]    @relation("PortalAuthorizationRevokedBy")
  portalSupportingDocumentsShared SupportingDocument[]           @relation("PortalDocumentSharedBy")
  portalPacketDocumentsShared     PacketDocument[]               @relation("PortalPacketDocumentSharedBy")
  portalDocumentRequestsCreated   PortalDocumentRequest[]        @relation("PortalDocumentRequestCreatedBy")
  portalDocumentRequestsCancelled PortalDocumentRequest[]        @relation("PortalDocumentRequestCancelledBy")
  portalDocumentTimelineEvents    PortalDocumentTimelineEvent[]
  portalDocumentReviewFeedback    PortalDocumentReviewFeedback[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @map("refresh_token")
  accessToken       String? @map("access_token")
  expiresAt         BigInt? @map("expires_at")
  tokenType         String? @map("token_type")
  scope             String?
  idToken           String? @map("id_token")
  sessionState      String? @map("session_state")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id             String   @id @default(cuid())
  sessionToken   String   @unique
  userId         String
  expires        DateTime
  organizationId String?  @map("organization_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model OrganizationMember {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  userId         String       @map("user_id")
  role           UserRole
  status         MemberStatus @default(ACTIVE)
  departments    Json         @default("[]")
  permissions    Json         @default("{}")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_members")
}

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(cuid())
  role         UserRole
  permissionId String   @map("permission_id")
  createdAt    DateTime @default(now())

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@map("role_permissions")
}

model Program {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  code           String
  description    String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  enrollments     ClientProgram[]
  packetTemplates PacketTemplate[]
  packets         Packet[]

  @@unique([organizationId, code])
  @@map("programs")
}

model ClientProgram {
  id        String    @id @default(cuid())
  clientId  String    @map("client_id")
  programId String    @map("program_id")
  status    String    @default("active")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([clientId, programId])
  @@map("client_programs")
}

model ClientContact {
  id           String   @id @default(cuid())
  clientId     String   @map("client_id")
  firstName    String   @map("first_name")
  lastName     String   @map("last_name")
  relationship String
  email        String?
  phone        String?
  address      String?
  isEmergency  Boolean  @default(false) @map("is_emergency")
  isGuardian   Boolean  @default(false) @map("is_guardian")
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client                  Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  portalClientAccess      PortalClientAccess[]
  portalInvitations       PortalInvitation[]
  portalSignatureRequests SignatureRequest[]

  @@map("client_contacts")
}

model StaffAssignment {
  id          String    @id @default(cuid())
  clientId    String    @map("client_id")
  staffUserId String    @map("staff_user_id")
  role        String    @default("case_manager")
  isPrimary   Boolean   @default(false) @map("is_primary")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  staff  User   @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@unique([clientId, staffUserId, role])
  @@map("staff_assignments")
}

model Diagnosis {
  id          String    @id @default(cuid())
  clientId    String    @map("client_id")
  code        String
  description String?
  type        String    @default("primary")
  isActive    Boolean   @default(true)
  onsetDate   DateTime? @map("onset_date")
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@map("diagnoses")
}

model Client {
  id                String    @id @default(cuid())
  organizationId    String    @map("organization_id")
  firstName         String    @map("first_name")
  lastName          String    @map("last_name")
  dateOfBirth       DateTime? @map("date_of_birth")
  email             String?
  phone             String?
  address           String?
  city              String?
  state             String?
  zipCode           String?   @map("zip_code")
  mcadId            String?   @map("mcad_id")
  ssn               String?   @map("ssn")
  gender            String?
  preferredLanguage String?   @map("preferred_language")
  status            String    @default("active")
  program           String?
  fundingSource     String?   @map("funding_source")
  notes             String?
  archivedAt        DateTime? @map("archived_at")
  archivedReason    String?   @map("archived_reason")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  organization           Organization                @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packets                Packet[]
  enrollments            ClientProgram[]
  contacts               ClientContact[]
  assignments            StaffAssignment[]
  diagnoses              Diagnosis[]
  supportingDocuments    SupportingDocument[]
  portalAccess           PortalClientAccess[]
  portalInvitations      PortalInvitation[]
  portalAuthorizations   PortalAccessAuthorization[]
  portalNotifications    PortalNotification[]
  portalAuditEvents      PortalAuditEvent[]
  portalDocumentRequests PortalDocumentRequest[]

  @@index([organizationId, status])
  @@index([organizationId, firstName, lastName])
  @@index([organizationId, mcadId])
  @@index([status])
  @@map("clients")
}

model DocumentTemplate {
  id                String   @id @default(cuid())
  organizationId    String   @map("organization_id")
  name              String
  description       String?
  formType          String   @default("dhs") @map("form_type")
  packetTypes       Json     @default("[]")
  program           String?
  status            String   @default("draft")
  version           Int      @default(1)
  previousVersionId String?  @map("previous_version_id")
  fileUrl           String   @map("file_url")
  fileKey           String   @map("file_key")
  fileSize          Int?     @map("file_size")
  mimeType          String   @default("application/pdf") @map("mime_type")
  uploadedById      String   @map("uploaded_by_id")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  uploadedBy         User                     @relation("TemplateUploads", fields: [uploadedById], references: [id])
  organization       Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packetDocuments    PacketDocument[]
  packetTemplateDocs PacketTemplateDocument[]
  previousVersion    DocumentTemplate?        @relation("DocumentTemplateVersionChain", fields: [previousVersionId], references: [id], onDelete: SetNull)
  nextVersions       DocumentTemplate[]       @relation("DocumentTemplateVersionChain")
  fields             DocumentTemplateField[]

  @@map("document_templates")
}

// Reusable field layout for a DocumentTemplate — seeded into real PdfField
// rows (source: "template") whenever a packet is created from a template
// that maps to this document. Coordinates use the exact same convention as
// PdfField/FieldOverlays: pixels on the PDF canvas rendered at scale 1.5.
model DocumentTemplateField {
  id                 String   @id @default(cuid())
  organizationId     String   @map("organization_id")
  documentTemplateId String   @map("document_template_id")
  fieldKey           String   @map("field_key")
  name               String
  fieldType          String   @default("text") @map("field_type")
  pageNumber         Int      @default(1) @map("page_number")
  posX               Float?   @map("pos_x")
  posY               Float?   @map("pos_y")
  width              Float?
  height             Float?
  isRequired         Boolean  @default(false) @map("is_required")
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization     Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documentTemplate DocumentTemplate         @relation(fields: [documentTemplateId], references: [id], onDelete: Cascade)
  conditionGroups  TemplateConditionGroup[]
  pdfFields        PdfField[]

  @@unique([documentTemplateId, fieldKey])
  @@map("document_template_fields")
}

// ── Stage 5 Step 4a: Conditional Logic Foundation ──
// Schema/CRUD/evaluator only in this step — no runtime hiding, no packet
// seeding integration, no validation-engine integration yet. See
// docs/UI_CORRECTION_STATUS.md for the full phased plan.

enum ConditionPurpose {
  FIELD_VISIBILITY
  FIELD_REQUIREDNESS
  DOCUMENT_INCLUSION
  DOCUMENT_REQUIREDNESS
  VALIDATION_RULE_APPLICABILITY
}

enum ConditionLogicOperator {
  AND
  OR
}

enum ConditionOperator {
  EQUALS
  NOT_EQUALS
  CONTAINS
  NOT_EMPTY
  EMPTY
  CHECKED
  UNCHECKED
  GREATER_THAN
  LESS_THAN
  BEFORE
  AFTER
  IN
  NOT_IN
}

// TEMPLATE_FIELD references another DocumentTemplateField.fieldKey on the
// same DocumentTemplate. The other three are fixed pseudo-fields — never a
// real column lookup, never raw client PHI (CLIENT_IS_MINOR is a derived
// boolean, never date of birth itself).
enum ConditionSourceType {
  TEMPLATE_FIELD
  CLIENT_IS_MINOR
  PACKET_PROGRAM_CODE
  PACKET_TYPE
}

// A condition tree's root node. Exactly one owner FK is set on a root group
// (enforced in application code, not a DB constraint, since Prisma/Postgres
// can't express "exactly one of N nullable FKs" declaratively). A nested
// group (parentGroupId set) has no owner of its own — it belongs to its root
// ancestor's owner. Max depth is 2: a root group, optionally containing one
// level of child groups — enforced in application code.
model TemplateConditionGroup {
  id                       String                 @id @default(cuid())
  organizationId           String                 @map("organization_id")
  purpose                  ConditionPurpose
  logicOperator            ConditionLogicOperator @default(AND) @map("logic_operator")
  parentGroupId            String?                @map("parent_group_id")
  documentTemplateFieldId  String?                @map("document_template_field_id")
  packetTemplateDocumentId String?                @map("packet_template_document_id")
  validationRuleId         String?                @map("validation_rule_id")
  createdAt                DateTime               @default(now())
  updatedAt                DateTime               @updatedAt

  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parentGroup            TemplateConditionGroup?  @relation("ConditionGroupChildren", fields: [parentGroupId], references: [id], onDelete: Cascade)
  childGroups            TemplateConditionGroup[] @relation("ConditionGroupChildren")
  documentTemplateField  DocumentTemplateField?   @relation(fields: [documentTemplateFieldId], references: [id], onDelete: Cascade)
  packetTemplateDocument PacketTemplateDocument?  @relation(fields: [packetTemplateDocumentId], references: [id], onDelete: Cascade)
  validationRule         ValidationRule?          @relation(fields: [validationRuleId], references: [id], onDelete: Cascade)
  conditions             TemplateCondition[]

  @@unique([documentTemplateFieldId, purpose])
  @@unique([packetTemplateDocumentId, purpose])
  @@unique([validationRuleId, purpose])
  @@index([documentTemplateFieldId])
  @@index([parentGroupId])
  @@map("template_condition_groups")
}

// A single leaf comparison within a group. sourceFieldKey is a plain string
// (not a FK) — the entire point of Step 2's stable fieldKey design is that
// conditions reference fields by key, not database id, so they survive
// version carryover without rewriting. Dependency protection (blocking a
// delete/rename of a referenced fieldKey) is therefore an application-level
// query, not a DB foreign-key constraint.
//
// sourcePacketTemplateDocumentId (Step 4b) disambiguates which document a
// cross-document TEMPLATE_FIELD reference's sourceFieldKey belongs to — the
// same fieldKey string can exist on multiple DocumentTemplates, so fieldKey
// alone is ambiguous once a condition can point outside its owner's own
// document. Only ever set on DOCUMENT_INCLUSION/DOCUMENT_REQUIREDNESS
// (PacketTemplateDocument-owned) conditions; field-owned conditions remain
// same-document-only and must leave this null (enforced in application code,
// not a DB constraint, matching the rest of this feature's ownership rules).
model TemplateCondition {
  id                             String              @id @default(cuid())
  groupId                        String              @map("group_id")
  sourceType                     ConditionSourceType @map("source_type")
  sourceFieldKey                 String?             @map("source_field_key")
  sourcePacketTemplateDocumentId String?             @map("source_packet_template_document_id")
  operator                       ConditionOperator
  comparisonValue                Json?               @map("comparison_value")
  sortOrder                      Int                 @default(0) @map("sort_order")
  createdAt                      DateTime            @default(now())
  updatedAt                      DateTime            @updatedAt

  group                        TemplateConditionGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sourcePacketTemplateDocument PacketTemplateDocument? @relation(fields: [sourcePacketTemplateDocumentId], references: [id], onDelete: Cascade)

  @@index([groupId])
  @@index([sourceFieldKey])
  @@index([sourcePacketTemplateDocumentId])
  @@map("template_conditions")
}

model PacketTemplate {
  id             String   @id @default(cuid())
  organizationId String   @map("organization_id")
  name           String
  description    String?
  packetType     String   @map("packet_type")
  programId      String?  @map("program_id")
  status         String   @default("active")
  isDefault      Boolean  @default(false) @map("is_default")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization       Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  program            Program?                  @relation(fields: [programId], references: [id], onDelete: SetNull)
  requiredDocs       PacketTemplateDocument[]
  packetInstances    Packet[]
  conditionSnapshots PacketConditionSnapshot[]

  @@map("packet_templates")
}

model PacketTemplateDocument {
  id                 String   @id @default(cuid())
  packetTemplateId   String   @map("packet_template_id")
  documentTemplateId String   @map("document_template_id")
  required           Boolean  @default(true)
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now())

  packetTemplate         PacketTemplate           @relation(fields: [packetTemplateId], references: [id], onDelete: Cascade)
  documentTemplate       DocumentTemplate         @relation(fields: [documentTemplateId], references: [id], onDelete: Cascade)
  conditionGroups        TemplateConditionGroup[]
  // Incoming cross-document references — conditions owned by OTHER mappings
  // in the same PacketTemplate whose TEMPLATE_FIELD source points at this
  // mapping's document (Step 4b).
  referencedByConditions TemplateCondition[]
  packetDocuments        PacketDocument[]

  @@unique([packetTemplateId, documentTemplateId])
  @@map("packet_template_documents")
}

model Packet {
  id                      String    @id @default(cuid())
  organizationId          String    @map("organization_id")
  clientId                String    @map("client_id")
  packetTemplateId        String?   @map("packet_template_id")
  programId               String?   @map("program_id")
  packetType              String    @map("packet_type")
  status                  String    @default("draft")
  assignedToId            String?   @map("assigned_to_id")
  dueDate                 DateTime? @map("due_date")
  completedAt             DateTime? @map("completed_at")
  metadata                Json      @default("{}")
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  conditionRuntimeVersion Int?      @map("condition_runtime_version")
  conditionSnapshotId     String?   @unique @map("condition_snapshot_id")

  organization           Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  client                 Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  packetTemplate         PacketTemplate?          @relation(fields: [packetTemplateId], references: [id], onDelete: SetNull)
  program                Program?                 @relation(fields: [programId], references: [id], onDelete: SetNull)
  assignedTo             User?                    @relation("AssignedPackets", fields: [assignedToId], references: [id], onDelete: SetNull)
  documents              PacketDocument[]
  validationResults      ValidationResult[]
  signatureRequests      SignatureRequest[]
  approvalRequests       ApprovalRequest[]
  supportingDocuments    SupportingDocument[]
  aiRecommendations      AiRecommendation[]
  portalDocumentRequests PortalDocumentRequest[]
  conditionSnapshot      PacketConditionSnapshot? @relation(fields: [conditionSnapshotId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([organizationId, clientId])
  @@index([organizationId, dueDate])
  @@index([status])
  @@map("packets")
}

// Immutable, definition-only runtime snapshot. It deliberately contains no
// client field values or raw DOB; isMinor is frozen at evaluationReferenceAt.
model PacketConditionSnapshot {
  id                    String   @id @default(cuid())
  organizationId        String   @map("organization_id")
  packetTemplateId      String   @map("packet_template_id")
  runtimeVersion        Int      @default(1) @map("runtime_version")
  evaluationReferenceAt DateTime @map("evaluation_reference_at")
  clientIsMinor         Boolean  @map("client_is_minor")
  definition            Json
  createdAt             DateTime @default(now())

  organization   Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  packetTemplate PacketTemplate @relation(fields: [packetTemplateId], references: [id], onDelete: Restrict)
  packet         Packet?

  @@index([organizationId, packetTemplateId])
  @@map("packet_condition_snapshots")
}

model PacketDocument {
  id                          String                            @id @default(cuid())
  packetId                    String                            @map("packet_id")
  documentTemplateId          String                            @map("document_template_id")
  status                      String                            @default("pending")
  isRequired                  Boolean                           @default(true) @map("is_required")
  sortOrder                   Int                               @default(0) @map("sort_order")
  currentVersion              Int                               @default(0) @map("current_version")
  completedAt                 DateTime?                         @map("completed_at")
  notes                       String?
  portalVisible               Boolean                           @default(false) @map("portal_visible")
  portalVisibleAt             DateTime?                         @map("portal_visible_at")
  sharedByUserId              String?                           @map("shared_by_user_id")
  portalAccessLevel           PortalDocumentAccessLevel?        @map("portal_access_level")
  createdAt                   DateTime                          @default(now())
  updatedAt                   DateTime                          @updatedAt
  packetTemplateDocumentId    String?                           @map("packet_template_document_id")
  applicabilityStatus         PacketDocumentApplicabilityStatus @default(ACTIVE) @map("applicability_status")
  conditionallyInactiveAt     DateTime?                         @map("conditionally_inactive_at")
  conditionallyInactiveReason String?                           @map("conditionally_inactive_reason")

  packet                 Packet                  @relation(fields: [packetId], references: [id], onDelete: Cascade)
  documentTemplate       DocumentTemplate        @relation(fields: [documentTemplateId], references: [id], onDelete: Cascade)
  fields                 PdfField[]
  versions               PdfVersion[]
  comments               DocumentComment[]
  aiExtractions          AiExtraction[]
  aiRecommendations      AiRecommendation[]
  validationResults      ValidationResult[]
  signatureRequests      SignatureRequest[]
  sharedBy               User?                   @relation("PortalPacketDocumentSharedBy", fields: [sharedByUserId], references: [id], onDelete: SetNull)
  portalDocumentRequests PortalDocumentRequest[]
  packetTemplateDocument PacketTemplateDocument? @relation(fields: [packetTemplateDocumentId], references: [id], onDelete: SetNull)

  @@unique([packetId, documentTemplateId])
  @@unique([packetId, packetTemplateDocumentId])
  @@index([packetTemplateDocumentId, applicabilityStatus])
  @@map("packet_documents")
}

model PdfField {
  id                      String   @id @default(cuid())
  packetDocumentId        String   @map("packet_document_id")
  name                    String
  fieldType               String   @default("text") @map("field_type")
  value                   String?
  pageNumber              Int      @default(1) @map("page_number")
  posX                    Float?   @map("pos_x")
  posY                    Float?   @map("pos_y")
  width                   Float?
  height                  Float?
  confidence              Float?   @default(1.0)
  source                  String   @default("manual")
  isRequired              Boolean  @default(false) @map("is_required")
  sortOrder               Int      @default(0) @map("sort_order")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  templateFieldKey        String?  @map("template_field_key")
  documentTemplateFieldId String?  @map("document_template_field_id")

  packetDocument        PacketDocument         @relation(fields: [packetDocumentId], references: [id], onDelete: Cascade)
  documentTemplateField DocumentTemplateField? @relation(fields: [documentTemplateFieldId], references: [id], onDelete: SetNull)
  signatureRequests     SignatureRequest[]

  @@unique([packetDocumentId, templateFieldKey])
  @@index([documentTemplateFieldId])
  @@map("pdf_fields")
}

model PdfVersion {
